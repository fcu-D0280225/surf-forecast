# 複製成 .env 後填入實際值

# Web Push VAPID
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=app_user
MYSQL_PASSWORD=
MYSQL_DATABASE=surf_forecast

# Langfuse 雲端版觀測性（留空則關閉 trace 蒐集）
# 到 https://cloud.langfuse.com 建立 project 後取得 public/secret key
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
